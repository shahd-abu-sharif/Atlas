// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ! ENUMS

enum UserRole {
  SUPER_ADMIN
  UNIVERSITY_ADMIN
  COMPANY_ADMIN
  UNIVERSITY_SUPERVISOR
  COMPANY_TRAINER
  STUDENT
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum InternshipStatus {
  ACTIVE
  COMPLETED
  CLOSED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TrainingType {
  REMOTE
  ONSITE
  HYBRID
}

enum AttendanceStatus {
  PRESENT //* arrivalTime ≤ startTime + gracePeriod
  ABSENT //* no check-in OR arrivalTime > lateLimit
  LATE //* startTime + gracePeriod < arrivalTime ≤ lateLimit
}

enum EvaluationType {
  AI
  TRAINER
  SUPERVISOR
}

enum NotificationType {
  TASK
  ANNOUNCEMENT
  APPLICATION
  EVALUATION
  SYSTEM
}

// ! User Model

model User {
  id                String                       @id @default(uuid())
  email             String                       @unique
  password          String
  fullName          String
  phone             String?
  profileImage      String?
  role              UserRole
  universityId      String?
  companyId         String?
  isActive          Boolean                      @default(true)
  studentProfile    StudentProfile?
  trainerProfile    CompanyTrainerProfile?
  supervisorProfile UniversitySupervisorProfile?

  createdAt DateTime @default(now())

  notifications         Notification[]
  sentMessages          Message[]      @relation("sent")
  receivedMessages      Message[]      @relation("recv")
  evaluations           Evaluation[]   @relation("UserEvaluations")
  trainerInternships    Internship[]   @relation("TrainerInternship")
  supervisorInternships Internship[]   @relation("SupervisorInternship")
}

// ! University Module

model University {
  id          String  @id @default(uuid())
  name        String
  email       String?
  phone       String?
  location    String?
  description String?
  isActive    Boolean @default(true)

  internships Internship[]
  students    StudentProfile[]
  supervisors UniversitySupervisorProfile[]
}

// ! Company Model

model Company {
  id          String  @id @default(uuid())
  name        String
  email       String?
  phone       String?
  location    String?
  description String?
  isActive    Boolean @default(true)

  internships   Internship[]
  trainers      CompanyTrainerProfile[]
  opportunities TrainingOpportunity[]
}

// ! Student Profile Model

model StudentProfile {
  userId               String    @id
  universityId         String?
  major                String?
  academicYear         Int?
  gpa                  Float?
  cvUrl                String?
  verificationDocument String?
  approvalStatus       String?
  approvedAt           DateTime?

  internships     InternshipStudent[]
  attendance      Attendance[]
  evaluations     Evaluation[]
  taskSubmissions TaskSubmission[]

  user       User        @relation(fields: [userId], references: [id])
  university University? @relation(fields: [universityId], references: [id])
}

// ! University Supervisor Profile Model

model UniversitySupervisorProfile {
  userId       String  @id
  universityId String?
  department   String?

  user       User        @relation(fields: [userId], references: [id])
  university University? @relation(fields: [universityId], references: [id])
}

// ! Company Trainer Profile Model

model CompanyTrainerProfile {
  userId         String  @id
  companyId      String?
  position       String?
  specialization String?

  company Company? @relation(fields: [companyId], references: [id])
  user    User     @relation(fields: [userId], references: [id])
}

// ! Training Opportunity Model

model TrainingOpportunity {
  id             String       @id @default(uuid())
  title          String
  description    String
  requiredSkills String?
  duration       String?
  totalSeats     Int
  location       String?
  meetingLink    String?
  isActive       Boolean      @default(true)
  type           TrainingType @default(ONSITE)

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  // internship  Internship? @relation("OppToInternship")
  internships Internship[]
}

// ! Internship Model

model Internship {
  id            String           @id @default(uuid())
  opportunityId String
  companyId     String
  universityId  String
  trainerId     String?
  supervisorId  String?
  status        InternshipStatus @default(ACTIVE)

  students    InternshipStudent[]
  attendance  Attendance[]
  evaluations Evaluation[]
  tasks       Task[]

  company     Company             @relation(fields: [companyId], references: [id])
  university  University          @relation(fields: [universityId], references: [id])
  opportunity TrainingOpportunity @relation(fields: [opportunityId], references: [id])
  trainer     User?               @relation("TrainerInternship", fields: [trainerId], references: [id])
  supervisor  User?               @relation("SupervisorInternship", fields: [supervisorId], references: [id])
  // opportunityId String @unique
  // opportunity   TrainingOpportunity @relation("OppToInternship", fields: [opportunityId], references: [id])
}

// ! Internship Student Model

model InternshipStudent {
  id           String @id @default(uuid())
  internshipId String
  studentId    String

  internship Internship     @relation(fields: [internshipId], references: [id])
  student    StudentProfile @relation(fields: [studentId], references: [userId])
}

// ! Task Model

model Task {
  id           String     @id @default(uuid())
  internshipId String
  title        String
  description  String?
  deadline     DateTime?
  status       TaskStatus @default(TODO)

  submissions TaskSubmission[]
  internship  Internship       @relation(fields: [internshipId], references: [id])
}

// ! Task Submission Model

model TaskSubmission {
  id          String   @id @default(uuid())
  taskId      String
  studentId   String
  fileUrl     String?
  score       Float?
  feedback    String?
  submittedAt DateTime @default(now())

  aiEvaluations AIEvaluation[]

  student StudentProfile @relation(fields: [studentId], references: [userId])
  task    Task           @relation(fields: [taskId], references: [id])
}

// ! Attendance Model

model Attendance {
  id           String           @id @default(uuid())
  internshipId String
  studentId    String
  date         DateTime
  status       AttendanceStatus

  internship Internship     @relation(fields: [internshipId], references: [id])
  student    StudentProfile @relation(fields: [studentId], references: [userId])
}

// ! Evaluation Model

model Evaluation {
  id           String         @id @default(uuid())
  internshipId String
  studentId    String
  evaluatorId  String
  type         EvaluationType
  score        Float?
  feedback     String?
  createdAt    DateTime       @default(now())

  evaluator  User           @relation("UserEvaluations", fields: [evaluatorId], references: [id])
  internship Internship     @relation(fields: [internshipId], references: [id])
  student    StudentProfile @relation(fields: [studentId], references: [userId])
}

// ! AI Evaluation Model

model AIEvaluation {
  id               String   @id @default(uuid())
  taskSubmissionId String
  score            Float?
  analysis         String?
  recommendations  String?
  createdAt        DateTime @default(now())

  taskSubmission TaskSubmission @relation(fields: [taskSubmissionId], references: [id])
}

// ! Message Model

model Message {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  content    String
  createdAt  DateTime @default(now())

  sender   User @relation("sent", fields: [senderId], references: [id])
  receiver User @relation("recv", fields: [receiverId], references: [id])
}

// ! Notification Model

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  body      String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  type      NotificationType

  user User @relation(fields: [userId], references: [id])
}
